# Base Dotfiles Configuration
# This is the base configuration that applies to all your machines
# Profile-specific overrides are in .dotfiles.dev.config, .dotfiles.personal.config, .dotfiles.server.config

# Git Configuration (applies to all machines)
GIT_NAME="jarmourato"
GIT_EMAIL="joao.armourato@gmail.com"
AUTO_SETUP_GIT_SSH=true

# SSH Configuration
SSH_KEY_TYPE="ed25519"
AUTO_CONFIGURE_GITHUB_SSH=true

# Base packages that every machine should have
BASE_HOMEBREW_FORMULAS="git gh jq curl wget tree bat fd ripgrep htop neovim"
BASE_HOMEBREW_CASKS=""

# Security settings
ENCRYPTION_METHOD="age"
SECRETS_WARNING_DAYS=90
CREATE_SNAPSHOT=true

# System preferences (macOS defaults that apply everywhere)
SETUP_MACOS_DEFAULTS=true
SKIP_XCODE=false  # You might want Xcode tools everywhere

# Sync settings
ENABLE_MACHINE_SYNC=true
AUTO_SYNC_ENABLED=false  # Manual sync by default

# Skip categories (can be overridden by profiles)
SKIP_HOMEBREW=false
SKIP_MAS_APPS=true  # Skip Mac App Store by default, enable in profiles if needed
SKIP_RUBY_INSTALL=true
SKIP_PYTHON_INSTALL=false
SKIP_NODE_INSTALL=false

# Maintenance
AUTO_MAINTENANCE_ENABLED=true
DAILY_HEALTH_CHECK=true

# Default to minimal mode (profiles will override with additional packages)
MINIMAL_PACKAGES=true