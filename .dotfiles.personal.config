# Personal Machine Profile
# This config extends the base configuration for personal use

# Personal machine settings
MINIMAL_PACKAGES=false
DEVELOPMENT_TYPE="general"

# Personal productivity and entertainment apps
HOMEBREW_FORMULAS="$BASE_HOMEBREW_FORMULAS youtube-dl ffmpeg imagemagick"

# Personal GUI applications
HOMEBREW_CASKS="google-chrome firefox spotify telegram whatsapp discord zoom"

# Personal productivity tools
ADDITIONAL_CASKS="notion obsidian 1password bitwarden dropbox google-drive iina vlc handbrake"

# Entertainment and media
PERSONAL_CASKS="steam epic-games-launcher nvidia-geforce-now netflix"

# Photo and video editing
CREATIVE_CASKS="adobe-creative-cloud final-cut-pro logic-pro"

# Personal convenience tools
CONVENIENCE_CASKS="cleanmymac bartender alfred raycast rectangle"

# Enable Mac App Store apps for personal use
SKIP_MAS_APPS=false

# Personal Mac App Store apps (you can add your owned apps)
MAS_APPS="904280696:Things_3 1477385213:Save_to_Pocket 1295203466:Microsoft_Remote_Desktop"

# Personal development (lighter than dev machine)
SKIP_XCODE=false  # Enable Xcode on personal machine too
SKIP_PYTHON_INSTALL=false
SKIP_NODE_INSTALL=false
PYTHON_VERSIONS="3.11"
NODE_VERSION="lts"

# Personal Git config (same as base but with different editor preference)
GIT_EDITOR="nano"

# Terminal preferences for personal use
ENABLE_POWERLINE=true
TERMINAL_THEME="basic"

# Personal-specific features
SETUP_PERSONAL_ALIASES=true
ENABLE_FUN_COMMANDS=true

# Machine profile identifier
MACHINE_PROFILE="personal"