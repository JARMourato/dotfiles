# Server Machine Profile (Mac Mini)
# This config extends the base configuration for server/headless use

# Server-specific settings
MINIMAL_PACKAGES=true
DEVELOPMENT_TYPE="devops"

# Server-focused tools (no GUI apps)
HOMEBREW_FORMULAS="$BASE_HOMEBREW_FORMULAS docker docker-compose docker-buildx"

# Container and orchestration tools
SERVER_FORMULAS="kubernetes-cli helm terraform ansible portainer-cli"

# Monitoring and server management
MONITORING_FORMULAS="htop iftop nethogs ncdu tmux screen"

# Network and file transfer tools
NETWORK_FORMULAS="rsync scp ssh-copy-id mosh nmap"

# No GUI applications for server
HOMEBREW_CASKS=""
SKIP_CASKS=true

# Skip unnecessary components for server
SKIP_MAS_APPS=true
SKIP_XCODE=true  # Server doesn't need Xcode
SKIP_TERMINAL_SETUP=true  # Minimal terminal setup
SKIP_MACOS_DEFAULTS=true  # Don't change system preferences on server

# Minimal language support
SKIP_PYTHON_INSTALL=false  # Keep Python for server scripts
SKIP_NODE_INSTALL=true     # Skip Node.js unless needed
SKIP_RUBY_INSTALL=true
PYTHON_VERSIONS="3.11"

# Server-specific Git config
GIT_EDITOR="nano"

# Disable GUI features
ENABLE_POWERLINE=false
SETUP_CUSTOM_TERMINAL=false

# Server security and management
ENABLE_SSH_HARDENING=true
SETUP_FAIL2BAN=false  # macOS doesn't have fail2ban, but we can add similar tools later
ENABLE_AUTO_UPDATES=true

# Container-specific settings (for future Docker setup)
DOCKER_COMPOSE_VERSION="latest"
ENABLE_DOCKER_DAEMON=true

# Server monitoring and health
ENABLE_SERVER_MONITORING=true
SETUP_LOG_ROTATION=true

# Backup and maintenance
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_FREQUENCY="daily"

# Network services (for future setup)
ENABLE_SSH_SERVER=true
SETUP_VPN_SERVER=false  # Can enable later

# Machine profile identifier
MACHINE_PROFILE="server"

# Server-specific aliases and functions
SETUP_SERVER_ALIASES=true