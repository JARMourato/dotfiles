# User and group IDs - find these by running 'id' command
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Lisbon

# API Keys - get from each app's Settings > General
SONARR_API_KEY=your_sonarr_api_key
RADARR_API_KEY=your_radarr_api_key
PROWLARR_API_KEY=your_prowlarr_api_key
TAUTULLI_API_KEY=your_tautulli_api_key

# Notifiarr
NOTIFIARR_API_KEY=your_notifiarr_api_key

# qBittorrent
QBIT_USER=admin
QBIT_PASS=your_qbit_password

# Plex
PLEX_TOKEN=your_plex_token

# Kometa (Plex Meta Manager)
TMDB_API_KEY=your_tmdb_api_key
OMDB_API_KEY=your_omdb_api_key

# Cloudflare Tunnel
CLOUDFLARED_TOKEN=your_cloudflared_token
