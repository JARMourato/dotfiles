# Development Machine Profile
# This config extends the base configuration for development work

# Override base settings for development
MINIMAL_PACKAGES=false
DEVELOPMENT_TYPE="swift"  # Since you do Swift/iOS development

# Development Tools - Swift/iOS Focus
HOMEBREW_FORMULAS="$BASE_HOMEBREW_FORMULAS swiftlint swiftformat carthage cocoapods fastlane xcbeautify"

# Development Apps
HOMEBREW_CASKS="xcode simulator sf-symbols proxyman charles visual-studio-code sublime-text sourcetree github-desktop figma"

# Additional development tools
ADDITIONAL_FORMULAS="docker docker-compose kubernetes-cli terraform ansible aws-cli"

# Development-specific casks
ADDITIONAL_CASKS="postman insomnia raycast alfred rectangle cleanmymac"

# Enable Xcode and related tools
SKIP_XCODE=false
SETUP_XCODE_TEMPLATES=true

# Python/Node for development
SKIP_PYTHON_INSTALL=false
SKIP_NODE_INSTALL=false
PYTHON_VERSIONS="3.11 3.12"
NODE_VERSION="lts"

# Development-specific Git config
GIT_EDITOR="code --wait"
GIT_DIFF_TOOL="vscode"
GIT_MERGE_TOOL="vscode"

# Enable useful development features
ENABLE_POWERLINE=true
ENABLE_AUTOSUGGESTIONS=true
ENABLE_SYNTAX_HIGHLIGHTING=true

# QuickLook plugins for development
QUICKLOOK_PLUGINS="qlcolorcode qlmarkdown qlstephen qlprettypatch quicklookapk webpquicklook"

# Terminal enhancements
TERMINAL_THEME="pro"
SETUP_CUSTOM_TERMINAL=true

# Development-specific aliases and functions
SETUP_DEV_ALIASES=true

# Machine profile identifier
MACHINE_PROFILE="dev"